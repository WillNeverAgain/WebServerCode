{
  "schemaVersion": 1,
  "server": {
    "name": "LocalHtmlServer",
    "host": "127.0.0.1",
    "port": 8787,
    "enforceHost": true,
    "allowedHosts": [
      "localhost",
      "127.0.0.1",
      "::1"
    ]
  },
  "site": {
    "domain": "ordinarydaysgone.cn"
  },
  "git": {
    "dailyTime": "03:20",
    "framework": {
      "enabled": true,
      "localPath": ".",
      "remote": "origin",
      "branch": "main"
    },
    "web": {
      "enabled": true,
      "url": "https://github.com/WillNeverAgain/WebCode.git",
      "localPath": "webapps/current",
      "remote": "origin",
      "branch": "main",
      "mode": "auto",
      "entry": "server-entry.js",
      "staticEntry": "index.html",
      "staticRoot": ".",
      "spaFallback": true,
      "htmlCacheControl": "no-store",
      "staticCacheControl": "public, max-age=300",
      "cloneIfMissing": true,
      "pullOnStart": false,
      "fallbackToBundledExample": true,
      "bundledExamplePath": "examples/web-repo"
    },
    "afterUpdate": {
      "restartServer": true,
      "restartCloudflared": true
    }
  },
  "cloudflared": {
    "enabled": true,
    "autoStart": true,
    "autoInstall": true,
    "autoSetup": true,
    "autoLogin": true,
    "autoCreateTunnel": true,
    "autoRouteDns": true,
    "overwriteDns": true,
    "tunnelName": "NeverAgain",
    "configFile": "config/cloudflared.generated.yml",
    "logFile": "logs/cloudflared.log",
    "protocol": "http2",
    "edgeIpVersion": "4",
    "proxyUrl": "http://127.0.0.1:7897",
    "activeCheckSeconds": 45,
    "serviceUrl": "http://127.0.0.1:8787",
    "stateFile": "config/cloudflared.local.json"
  },
  "securityHeaders": {
    "X-Content-Type-Options": "nosniff",
    "Referrer-Policy": "no-referrer",
    "X-Frame-Options": "SAMEORIGIN"
  }
}
